# ─── Production Environment Template ─────────────────────────────────────────
# Copy this file to .env.prod, fill in all values, and NEVER commit .env.prod
# to version control.
#
# Required for docker-compose.prod.yml substitution:
#   DB_USER, DB_PASSWORD, DB_NAME
#   REDIS_PASSWORD
#   RABBITMQ_USER, RABBITMQ_PASSWORD
#   MINIO_ACCESS_KEY, MINIO_SECRET_KEY

# ─── Database (used by postgres service + injected into DATABASE_URL) ─────────
DB_USER=woles
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=woles

# Full URL is constructed by docker-compose.prod.yml using the vars above.
# Set DATABASE_URL here for the migrate command if running outside compose:
DATABASE_URL=postgres://woles:CHANGE_ME_strong_db_password@postgres:5432/woles?sslmode=disable

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# ─── Message Broker ──────────────────────────────────────────────────────────
RABBITMQ_USER=woles
RABBITMQ_PASSWORD=CHANGE_ME_strong_rabbitmq_password
RABBITMQ_URL=amqp://woles:CHANGE_ME_strong_rabbitmq_password@rabbitmq:5672/

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
# Mount the keys directory into the container (or bake them in at build time
# for immutable deploys). The paths below assume the keys are mounted at /app/keys/.
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# ─── Object Storage (MinIO) ──────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_min_16_chars
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=woles-documents
MINIO_USE_SSL=false

# Storage env vars consumed directly by the Go binary:
STORAGE_ENDPOINT=minio:9000
STORAGE_BUCKET=woles-documents
STORAGE_ACCESS_KEY=CHANGE_ME_minio_access_key
STORAGE_SECRET_KEY=CHANGE_ME_minio_secret_key_min_16_chars

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=fonnte
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_whatsapp_webhook_secret

# ─── AI ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=CHANGE_ME_openai_api_key

# ─── Payment ─────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=midtrans
PAYMENT_SECRET_KEY=CHANGE_ME_midtrans_server_key
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_payment_webhook_secret

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
APP_BASE_URL=https://api.woles.id
APP_SECRET=CHANGE_ME_32_char_random_hex_secret

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://woles.id,https://www.woles.id

# ─── Webhook signatures ──────────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_webhook_hmac_secret
