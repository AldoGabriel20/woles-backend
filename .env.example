# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://woles:woles@localhost:5432/woles?sslmode=disable

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Message Broker ──────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://woles:woles@localhost:5672/

# ─── JWT (RS256) ─────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=fonnte
WHATSAPP_WEBHOOK_SECRET=replace_with_webhook_secret

# ─── AI ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=replace_with_api_key

# ─── Object Storage (MinIO / S3-compatible) ──────────────────────────────────
STORAGE_ENDPOINT=localhost:9000
STORAGE_BUCKET=woles-documents
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ─── Payment ─────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=midtrans
PAYMENT_SECRET_KEY=replace_with_payment_secret_key
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
