{
  "info": {
    "_postman_id": "woles-api-v1",
    "name": "Woles API",
    "description": "Woles — WhatsApp-first personal life administration assistant.\n\nAll authenticated requests require a valid RS256 JWT in the Authorization header.\nRefresh tokens are stored as HttpOnly cookies and are managed automatically.\n\n**Setup:** Import `woles.postman_environment.json` alongside this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh expired access token before every request",
          "const token = pm.environment.get('access_token');",
          "if (!token) return;",
          "",
          "// Decode JWT payload (no signature verification needed here)",
          "function decodeJwtExp(jwt) {",
          "    try {",
          "        const parts = jwt.split('.');",
          "        if (parts.length !== 3) return null;",
          "        const payload = JSON.parse(atob(parts[1]));",
          "        return payload.exp || null;",
          "    } catch (e) { return null; }",
          "}",
          "",
          "const exp = decodeJwtExp(token);",
          "if (!exp) return;",
          "",
          "const nowSec = Math.floor(Date.now() / 1000);",
          "const bufferSec = 30; // refresh 30s before actual expiry",
          "",
          "if (exp - nowSec < bufferSec) {",
          "    const baseUrl = pm.environment.get('base_url');",
          "    pm.sendRequest({",
          "        url: baseUrl + '/auth/refresh',",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' }",
          "    }, function (err, res) {",
          "        if (!err && res.code === 200) {",
          "            const body = res.json();",
          "            if (body.access_token) {",
          "                pm.environment.set('access_token', body.access_token);",
          "            }",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
